# ======================================
# متغيرات البيئة المطلوبة في Vercel
# انسخ هذا الملف وأضف القيم الحقيقية في لوحة Vercel
# لا ترفع .env الحقيقي إلى GitHub أبداً
# ======================================

# قاعدة البيانات (Neon PostgreSQL)
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# Claude AI
CLAUDE_API_KEY=sk-ant-...

# Paymob
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# حماية إعداد DB
SETUP_SECRET=my-secret-key

# JWT للمصادقة (يجب أن يكون سلسلة عشوائية طويلة)
JWT_SECRET=changeme-use-a-random-32-char-string-here

# Resend (إرسال إيميل استعادة كلمة السر)
RESEND_API_KEY=re_...
SITE_URL=https://www.eses.store
SENDER_EMAIL=support@eses.store
